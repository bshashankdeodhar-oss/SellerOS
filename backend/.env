# ─────────────────────────────────────────────
#  SellerOS Backend — Environment Variables
#  Copy this file as .env and fill in your values
# ─────────────────────────────────────────────

# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=tiger
DB_NAME=selleros

# Server
PORT=3001

# CORS — set to your frontend origin in production
# For local development, leave as * to allow all
CORS_ORIGIN=*
